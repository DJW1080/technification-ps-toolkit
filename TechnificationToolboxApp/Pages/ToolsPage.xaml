<Page
    x:Class="TechnificationToolboxApp.Pages.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource PagePadding}"
          RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Style="{StaticResource CompactCommandBarStyle}">
            <AppBarButton Label="Toolbox"
                          Click="LaunchToolboxButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="OpenFile" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Logs"
                          Click="OpenLogsButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Folder" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Reports"
                          Click="OpenReportsButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Document" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <ListView x:Name="ToolsListView"
                  Grid.Row="1"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Margin="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Padding="10,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="17"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Description}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource SecondaryTextBlockStyle}" />
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,6,0,0">
                                    <TextBlock Text="{Binding Version}"
                                               Style="{StaticResource SecondaryTextBlockStyle}" />
                                    <TextBlock Margin="14,0,0,0"
                                               Text="{Binding ExperienceLabel}"
                                               Style="{StaticResource SecondaryTextBlockStyle}" />
                                    <TextBlock Margin="14,0,0,0"
                                               Text="{Binding RunModeLabel}"
                                               Style="{StaticResource SecondaryTextBlockStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Native"
                                    Tag="{Binding}"
                                    IsEnabled="{Binding HasNativePage}"
                                    Click="OpenNativeButton_Click"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0" />
                            <Button Grid.Column="2"
                                    Content="Open"
                                    Tag="{Binding}"
                                    Click="LaunchToolButton_Click"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    VerticalAlignment="Center"
                                    Margin="10,0,0,0" />
                            <Button Grid.Column="3"
                                    Content="Admin"
                                    Tag="{Binding}"
                                    Click="LaunchToolAsAdminButton_Click"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    VerticalAlignment="Center"
                                    Margin="10,0,0,0" />
                        </Grid>
                        <Border Margin="0,10,0,0"
                                Height="1"
                                Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
