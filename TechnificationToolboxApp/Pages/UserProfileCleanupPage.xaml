<Page
    x:Class="TechnificationToolboxApp.Pages.UserProfileCleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TechnificationToolboxApp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource PagePadding}"
          RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="User Profile Cleanup"
                       Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock Margin="0,6,0,0"
                       Text="Deep current-user cleanup with exclusions, category runs, and locked-file reporting."
                       TextWrapping="Wrap"
                       Style="{StaticResource SecondaryTextBlockStyle}" />
        </StackPanel>

        <CommandBar x:Name="CleanupCommandBar"
                    Grid.Row="1"
                    Style="{StaticResource CompactCommandBarStyle}">
            <AppBarButton x:Name="DeepScanButton"
                          Label="Scan"
                          Click="DeepScanButton_Click" />
            <AppBarButton x:Name="CategoriesButton"
                          Label="Categories"
                          Click="CategoriesButton_Click" />
            <AppBarButton x:Name="TempButton"
                          Label="Temp"
                          Click="TempButton_Click" />
            <AppBarButton x:Name="BrowserButton"
                          Label="Browser"
                          Click="BrowserButton_Click" />
            <AppBarButton x:Name="AppCacheButton"
                          Label="App Cache"
                          Click="AppCacheButton_Click" />

            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="CrashDataButton"
                              Label="Crash Data"
                              Click="CrashDataButton_Click" />
                <AppBarButton x:Name="LogsButton"
                              Label="Logs"
                              Click="LogsButton_Click" />
                <AppBarButton x:Name="LockedButton"
                              Label="Locked"
                              Click="LockedButton_Click" />
                <AppBarButton x:Name="ExclusionsButton"
                              Label="Exclusions"
                              Click="ExclusionsButton_Click" />
                <AppBarSeparator />
                <AppBarButton Label="Reports"
                              Click="OpenReportsButton_Click" />
                <AppBarButton Label="Logs Folder"
                              Click="OpenLogsButton_Click" />
                <AppBarButton Label="Legacy"
                              Click="LegacyMenuButton_Click" />
                <AppBarButton Label="Refresh"
                              Click="RefreshStatusButton_Click" />
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <Grid Grid.Row="2"
              ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Targets" />
                <TextBlock x:Name="TargetCountTextBlock"
                           Grid.Column="1"
                           Margin="10,0,0,0" />

                <TextBlock Grid.Row="1"
                           Text="Exclusions"
                           Margin="0,8,0,0" />
                <TextBlock x:Name="ExclusionCountTextBlock"
                           Grid.Row="1"
                           Grid.Column="1"
                           Margin="10,8,0,0" />

                <TextBlock Grid.Row="2"
                           Text="Locked"
                           Margin="0,8,0,0" />
                <TextBlock x:Name="LockedCountTextBlock"
                           Grid.Row="2"
                           Grid.Column="1"
                           Margin="10,8,0,0" />

                <TextBlock Grid.Row="3"
                           Text="Logs"
                           Margin="0,8,0,0" />
                <TextBlock x:Name="LogsPathTextBlock"
                           Grid.Row="3"
                           Grid.Column="1"
                           Margin="10,8,0,0"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="4"
                           Text="Reports"
                           Margin="0,8,0,0" />
                <TextBlock x:Name="ReportsPathTextBlock"
                           Grid.Row="4"
                           Grid.Column="1"
                           Margin="10,8,0,0"
                           TextWrapping="Wrap" />
            </Grid>

            <Grid Grid.Column="1"
                  RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox x:Name="ExclusionPatternTextBox"
                         Header="Exclusion Pattern"
                         PlaceholderText="*.tmp or keepme.log" />
                <TextBlock Grid.Row="1"
                           Text="Use the same pattern box for add and remove."
                           Style="{StaticResource SecondaryTextBlockStyle}" />
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal">
                    <Button x:Name="AddExclusionButton"
                            Content="Add"
                            Style="{StaticResource CompactPageButtonStyle}"
                            Click="AddExclusionButton_Click" />
                    <Button Margin="12,0,0,0"
                            Content="Remove"
                            Style="{StaticResource CompactPageButtonStyle}"
                            Click="RemoveExclusionButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Row="3"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ProgressBar x:Name="BusyProgressBar"
                         Visibility="Collapsed"
                         IsIndeterminate="True" />

            <Grid Grid.Row="1"
                  ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Activity"
                               Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <controls:ActivityConsole x:Name="OutputConsole"
                                             Grid.Row="1" />
                </Grid>

                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Run Status"
                                   Style="{StaticResource SectionTitleTextBlockStyle}" />
                        <TextBlock Text="Last action"
                                   Margin="0,10,0,0" />
                        <TextBlock x:Name="LastActionTextBlock"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Last result"
                                   Margin="0,12,0,0" />
                        <TextBlock x:Name="LastResultTextBlock"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Reports"
                                   Margin="0,12,0,0" />
                        <TextBox x:Name="ReportPathsTextBox"
                                 Margin="0,6,0,0"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 MinHeight="110"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,14,0,0">
                            <Button x:Name="OpenLatestReportButton"
                                    Content="Latest"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="OpenLatestReportButton_Click" />
                            <Button Margin="12,0,0,0"
                                    Content="Reports"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="OpenReportsButton_Click" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,10,0,0">
                            <Button Content="Logs"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="OpenLogsButton_Click" />
                            <Button Margin="12,0,0,0"
                                    Content="Legacy"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="LegacyMenuButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>

