<Page
    x:Class="TechnificationToolboxApp.Pages.WingetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TechnificationToolboxApp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource PagePadding}"
          RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Winget Maintenance"
                       Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock Margin="0,6,0,0"
                       Text="Core Winget actions with visible output and reports."
                       TextWrapping="Wrap"
                       Style="{StaticResource SecondaryTextBlockStyle}" />
        </StackPanel>

        <CommandBar x:Name="WingetCommandBar"
                    Grid.Row="1"
                    Style="{StaticResource CompactCommandBarStyle}">
            <AppBarButton x:Name="RecommendedButton"
                          Label="Recommended"
                          Click="RecommendedButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Play" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="VersionButton"
                          Label="Version"
                          Click="VersionButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Help" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="RefreshSourcesButton"
                          Label="Sources"
                          Click="RefreshSourcesButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Sync" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="ListUpgradesButton"
                          Label="Upgrades"
                          Click="ListUpgradesButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Download" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="ExportInventoryButton"
                          Label="Inventory"
                          Click="ExportInventoryButton_Click">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Document" />
                </AppBarButton.Icon>
            </AppBarButton>

            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="UpgradeAllButton"
                              Label="Upgrade All"
                              Click="UpgradeAllButton_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Download" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="ResetSourcesButton"
                              Label="Reset"
                              Click="ResetSourcesButton_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Delete" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator />
                <AppBarButton Label="Reports"
                              Click="OpenReportsButton_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Folder" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Logs"
                              Click="OpenLogsButton_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Folder" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Legacy"
                              Click="LegacyMenuButton_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="OpenFile" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Refresh"
                              Click="RefreshStatusButton_Click">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Refresh" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <Grid Grid.Row="2"
              ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Status" />
            <TextBlock x:Name="WingetStatusTextBlock"
                       Grid.Column="1"
                       Margin="10,0,0,0" />

            <TextBlock Grid.Row="1"
                       Text="Executable"
                       Margin="0,8,0,0" />
            <TextBlock x:Name="WingetPathTextBlock"
                       Grid.Row="1"
                       Grid.Column="1"
                       Margin="10,8,0,0"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="2"
                       Text="Reports"
                       Margin="0,8,0,0" />
            <TextBlock x:Name="ReportsPathTextBlock"
                       Grid.Row="2"
                       Grid.Column="1"
                       Margin="10,8,0,0"
                       TextWrapping="Wrap" />
        </Grid>

        <Grid Grid.Row="3"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ProgressBar x:Name="BusyProgressBar"
                         Visibility="Collapsed"
                         IsIndeterminate="True" />

            <Grid Grid.Row="1"
                  ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Activity"
                               Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <controls:ActivityConsole x:Name="OutputConsole"
                                             Grid.Row="1" />
                </Grid>

                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Run Status"
                                   Style="{StaticResource SectionTitleTextBlockStyle}" />
                        <TextBlock Text="Last action"
                                   Margin="0,10,0,0" />
                        <TextBlock x:Name="LastActionTextBlock"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Last result"
                                   Margin="0,12,0,0" />
                        <TextBlock x:Name="LastResultTextBlock"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Reports"
                                   Margin="0,12,0,0" />
                        <TextBox x:Name="ReportPathsTextBox"
                                 Margin="0,6,0,0"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 MinHeight="110"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,14,0,0">
                            <Button x:Name="OpenLatestReportButton"
                                    Content="Latest"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="OpenLatestReportButton_Click" />
                            <Button Margin="12,0,0,0"
                                    Content="Reports"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="OpenReportsButton_Click" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,10,0,0">
                            <Button Content="Logs"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="OpenLogsButton_Click" />
                            <Button Margin="12,0,0,0"
                                    Content="Legacy"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="LegacyMenuButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>

