<Page
    x:Class="TechnificationToolboxApp.Pages.EventLogCleanerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TechnificationToolboxApp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource PagePadding}"
          RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Event Log Cleaner"
                       Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock Margin="0,6,0,0"
                       Text="Manage exclusions, dry-run state, and live event log cleanup from the app."
                       TextWrapping="Wrap"
                       Style="{StaticResource SecondaryTextBlockStyle}" />
        </StackPanel>

        <CommandBar x:Name="CleanerCommandBar"
                    Grid.Row="1"
                    Style="{StaticResource CompactCommandBarStyle}">
            <AppBarButton x:Name="StartCleanerButton"
                          Label="Cleaner"
                          Click="StartCleanerButton_Click" />
            <AppBarButton x:Name="SettingsButton"
                          Label="Settings"
                          Click="SettingsButton_Click" />
            <AppBarButton x:Name="AddExactButton"
                          Label="Add Exact"
                          Click="AddExactButton_Click" />
            <AppBarButton x:Name="AddWildcardButton"
                          Label="Add Wildcard"
                          Click="AddWildcardButton_Click" />
            <AppBarButton x:Name="SaveConfigButton"
                          Label="Save"
                          Click="SaveConfigButton_Click" />

            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="RemoveExactButton"
                              Label="Remove Exact"
                              Click="RemoveExactButton_Click" />
                <AppBarButton x:Name="RemoveWildcardButton"
                              Label="Remove Wildcard"
                              Click="RemoveWildcardButton_Click" />
                <AppBarButton x:Name="LoadConfigButton"
                              Label="Load"
                              Click="LoadConfigButton_Click" />
                <AppBarButton x:Name="ResetDefaultsButton"
                              Label="Reset"
                              Click="ResetDefaultsButton_Click" />
                <AppBarSeparator />
                <AppBarButton Label="Reports"
                              Click="OpenReportsButton_Click" />
                <AppBarButton Label="Logs"
                              Click="OpenLogsButton_Click" />
                <AppBarButton Label="Legacy"
                              Click="LegacyMenuButton_Click" />
                <AppBarButton Label="Refresh"
                              Click="RefreshStatusButton_Click" />
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <Grid Grid.Row="2"
              ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Admin" />
                <TextBlock x:Name="AdminStatusTextBlock"
                           Grid.Column="1"
                           Margin="10,0,0,0" />

                <TextBlock Grid.Row="1"
                           Text="Dry Run"
                           Margin="0,8,0,0" />
                <TextBlock x:Name="DryRunStatusTextBlock"
                           Grid.Row="1"
                           Grid.Column="1"
                           Margin="10,8,0,0" />

                <TextBlock Grid.Row="2"
                           Text="Counts"
                           Margin="0,8,0,0" />
                <TextBlock x:Name="CountsStatusTextBlock"
                           Grid.Row="2"
                           Grid.Column="1"
                           Margin="10,8,0,0" />

                <TextBlock Grid.Row="3"
                           Text="Exact"
                           Margin="0,8,0,0" />
                <TextBlock x:Name="ExactCountTextBlock"
                           Grid.Row="3"
                           Grid.Column="1"
                           Margin="10,8,0,0" />

                <TextBlock Grid.Row="4"
                           Text="Wildcards"
                           Margin="0,8,0,0" />
                <TextBlock x:Name="WildcardCountTextBlock"
                           Grid.Row="4"
                           Grid.Column="1"
                           Margin="10,8,0,0" />

                <TextBlock Grid.Row="5"
                           Text="Config"
                           Margin="0,8,0,0" />
                <TextBlock x:Name="ConfigPathTextBlock"
                           Grid.Row="5"
                           Grid.Column="1"
                           Margin="10,8,0,0"
                           TextWrapping="Wrap" />
            </Grid>

            <Grid Grid.Column="1"
                  ColumnSpacing="10"
                  RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox x:Name="ExactExclusionTextBox"
                         Header="Exact Exclusion"
                         PlaceholderText="Security" />
                <TextBox x:Name="WildcardExclusionTextBox"
                         Grid.Column="1"
                         Header="Wildcard Exclusion"
                         PlaceholderText="Microsoft-Windows-Windows Defender/*" />
                <ToggleSwitch x:Name="DryRunToggleSwitch"
                              Grid.Row="1"
                              Header="Dry Run"
                              OffContent="Live"
                              OnContent="WhatIf"
                              Toggled="DryRunToggleSwitch_Toggled" />
                <ToggleSwitch x:Name="IncludeCountsToggleSwitch"
                              Grid.Row="1"
                              Grid.Column="1"
                              Header="Include Counts"
                              OffContent="Fast"
                              OnContent="Detailed"
                              Toggled="IncludeCountsToggleSwitch_Toggled" />
                <TextBlock Grid.Row="2"
                           Grid.ColumnSpan="2"
                           Text="Exact and wildcard boxes are reused for add and remove operations."
                           Style="{StaticResource SecondaryTextBlockStyle}" />
            </Grid>
        </Grid>

        <Grid Grid.Row="3"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ProgressBar x:Name="BusyProgressBar"
                         Visibility="Collapsed"
                         IsIndeterminate="True" />

            <Grid Grid.Row="1"
                  ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Activity"
                               Style="{StaticResource SectionTitleTextBlockStyle}" />
                    <controls:ActivityConsole x:Name="OutputConsole"
                                             Grid.Row="1" />
                </Grid>

                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Run Status"
                                   Style="{StaticResource SectionTitleTextBlockStyle}" />
                        <TextBlock Text="Last action"
                                   Margin="0,10,0,0" />
                        <TextBlock x:Name="LastActionTextBlock"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Last result"
                                   Margin="0,12,0,0" />
                        <TextBlock x:Name="LastResultTextBlock"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Reports"
                                   Margin="0,12,0,0" />
                        <TextBox x:Name="ReportPathsTextBox"
                                 Margin="0,6,0,0"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 MinHeight="110"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,14,0,0">
                            <Button x:Name="OpenLatestReportButton"
                                    Content="Latest"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="OpenLatestReportButton_Click" />
                            <Button Margin="12,0,0,0"
                                    Content="Reports"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="OpenReportsButton_Click" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,10,0,0">
                            <Button Content="Logs"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="OpenLogsButton_Click" />
                            <Button Margin="12,0,0,0"
                                    Content="Legacy"
                                    Style="{StaticResource CompactPageButtonStyle}"
                                    Click="LegacyMenuButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>

